# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL (Docker: see docker-compose.yml in this folder)
# DATABASE_URL=postgresql://postgres:secret@localhost:5432/financeboard
#
# SQLite — no Docker/Postgres needed; tables are created automatically.
# After changing URL, run: poetry run python seed.py
DATABASE_URL=sqlite:///./financeboard.db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-long-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
